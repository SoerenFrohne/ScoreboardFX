<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<fx:root type="javafx.scene.layout.VBox" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
         spacing="8.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="128.0" VBox.vgrow="ALWAYS">
            <children>
                <TextField fx:id="teamName" alignment="CENTER" maxHeight="1.7976931348623157E308"
                           maxWidth="1.7976931348623157E308" minHeight="64.0" minWidth="64.0" promptText="Heim"
                           HBox.hgrow="ALWAYS">
                    <font>
                        <Font name="System Bold" size="36.0"/>
                    </font>
                </TextField>
            </children>
        </HBox>
        <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="128.0"
              spacing="8.0" VBox.vgrow="ALWAYS">
            <children>
                <Button fx:id="goalButton" alignment="CENTER" maxHeight="1.7976931348623157E308"
                        maxWidth="1.7976931348623157E308" minHeight="64.0" minWidth="64.0" mnemonicParsing="false"
                        text="Tor" HBox.hgrow="ALWAYS"/>
                <Button fx:id="timeOutButton" alignment="CENTER" maxHeight="1.7976931348623157E308"
                        maxWidth="1.7976931348623157E308" minHeight="64.0" minWidth="64.0" mnemonicParsing="false"
                        text="Time-Out" HBox.hgrow="ALWAYS"/>
                <Button fx:id="penaltyButton" alignment="CENTER" maxHeight="1.7976931348623157E308"
                        maxWidth="1.7976931348623157E308" minHeight="64.0" minWidth="64.0" mnemonicParsing="false"
                        text="Zeitstrafe" HBox.hgrow="ALWAYS"/>
            </children>
        </HBox>
    </children>
    <opaqueInsets>
        <Insets/>
    </opaqueInsets>
    <padding>
        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0"/>
    </padding>
</fx:root>
