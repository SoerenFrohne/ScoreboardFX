<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="8.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="de.tvneheim.scoreboardfx.controller.GameActionsController">
    <children>
        <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
            <children>
                <Label fx:id="scoreHome" alignment="CENTER" contentDisplay="CENTER" layoutX="10.0" layoutY="10.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-background-color: #000;" text="00" textAlignment="CENTER" textFill="RED" HBox.hgrow="ALWAYS">
                    <font>
                        <Font name="Consolas Bold" size="50.0" />
                    </font>
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                </Label>
                <Label fx:id="clientTime" alignment="CENTER" contentDisplay="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-background-color: #000;" text="00:00" textAlignment="CENTER" textFill="#d1ff54" HBox.hgrow="ALWAYS">
                    <font>
                        <Font name="Consolas Bold" size="50.0" />
                    </font>
                </Label>
                <Label fx:id="scoreGuest" alignment="CENTER" contentDisplay="CENTER" layoutX="10.0" layoutY="10.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-background-color: #000;" text="00" textAlignment="CENTER" textFill="RED" HBox.hgrow="ALWAYS">
                    <font>
                        <Font name="Consolas Bold" size="50.0" />
                    </font>
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                </Label>
            </children>
        </HBox>
        <HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
            <children>
                <Button fx:id="startStopButton" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#toggleStartStop" text="Start" HBox.hgrow="ALWAYS">
                    <graphic>
                        <FontIcon iconLiteral="fas-play"></FontIcon>
                    </graphic>
                </Button>
                <Button fx:id="buzzer" layoutX="10.0" layoutY="10.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#honk" text="Hupe" HBox.hgrow="ALWAYS">
                    <graphic>
                        <FontIcon iconLiteral="fas-bullhorn" />
                    </graphic>
                </Button>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
    </padding>
</VBox>
